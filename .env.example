# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DATABASE_DIRECT_URL="postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres"

# JWT
JWT_SECRET="change-this-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-this-to-another-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
APP_ENCRYPTION_KEY="<32-byte-base64-key>"

# API
API_PORT=4000
API_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
